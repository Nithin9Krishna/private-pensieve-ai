<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml — Private Pensieve AI
     CRITICAL: No network permission. This is a V1 hard requirement.
     Enforced by CI policy checks. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Microphone: required for voice mode, requested just-in-time -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- No INTERNET permission — this app works fully offline -->
    <!-- No ACCESS_NETWORK_STATE — not needed -->
    <!-- No ACCESS_WIFI_STATE — not needed -->

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Private Pensieve"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrivatePensieve">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PrivatePensieve">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
